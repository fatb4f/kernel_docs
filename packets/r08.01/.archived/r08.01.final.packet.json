  "member_matrix": {
    "common_required_members": [
      {
        "name": "kind",
        "type": "string",
        "required": true,
        "rule": "constant = kernel-manifest-control"
      },
      {
        "name": "manifest_id",
        "type": "string",
        "required": true,
        "rule": "stable patterned identifier"
      },
      {
        "name": "spec_version",
        "type": "string",
        "required": true,
        "rule": "constant = v1"
      },
      {
        "name": "manifest_class",
        "type": "string",
        "required": true,
        "rule": "enum = bundle|projection|generator"
      },
      {
        "name": "status",
        "type": "string",
        "required": true,
        "rule": "enum = active|declared|deprecated"
      },
      {
        "name": "owner_plane",
        "type": "string",
        "required": true,
        "rule": "enum = policy|data_shaping"
      },
      {
        "name": "inputs",
        "type": "array<object>",
        "required": true,
        "rule": "structured refs only"
      },
      {
        "name": "outputs",
        "type": "array<object>",
        "required": true,
        "rule": "structured outputs only"
      },
      {
        "name": "admission",
        "type": "object",
        "required": true,
        "rule": "declares admission requirement and scope ref"
      },
      {
        "name": "regen",
        "type": "object",
        "required": true,
        "rule": "declares regeneration policy"
      },
      {
        "name": "notes",
        "type": "string",
        "required": false,
        "rule": "optional human note"
      }
    ],
    "structured_input_shape": {
      "required_members": [
        "ref",
        "input_kind",
        "required"
      ],
      "rules": [
        "ref is a repo-relative or logical contract reference",
        "input_kind identifies the dependency role",
        "required is boolean",
        "raw glob-only entries are not allowed in normative examples"
      ],
      "example": {
        "ref": "schemas/exported/exported-surface.index.json",
        "input_kind": "contract_index",
        "required": true
      }
    },
    "structured_output_shape": {
      "required_members": [
        "output_class",
        "path",
        "committed"
      ],
      "rules": [
        "output_class identifies the declared output family",
        "path is repo-relative and must stay under kernel/",
        "committed is boolean",
        "paths into build/ are forbidden"
      ],
      "example": {
        "output_class": "bundle_index",
        "path": "generated/state/bundles/kernel-core.index.json",
        "committed": true
      }
    },
    "class_specific_requirements": {
      "bundle": {
        "required_members": [
          "bundle_id",
          "bundle_scope",
          "includes",
          "excludes"
        ],
        "extra_rules": [
          "must not include runtime package paths",
          "must not include build/",
          "must not include external provider runtime artifacts"
        ]
      },
      "projection": {
        "required_members": [
          "projection_id",
          "input_state_class",
          "renderer_identity",
          "output_class"
        ],
        "extra_rules": [
          "renderer_identity may be declared but not executable in r08.01",
          "status should be declared for the initial projection manifest"
        ]
      },
      "generator": {
        "required_members": [
          "generator_id",
          "generator_identity",
          "contract_input_refs",
          "derived_output_classes"
        ],
        "extra_rules": [
          "generator_identity may be declared but not executable in r08.01",
          "status should be declared for the initial generator manifest"
        ]
      }
    },
    "surface_index_required_members": [
      "packet_id",
      "active_manifest_root",
      "manifests"
    ]
  },
